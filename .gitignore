/bin/
/roksbnkctl
*.test
*.out
*.exe
*.exe~
.DS_Store

# roksbnkctl-managed state, never commit
.roksbnkctl/

# IDE
.vscode/
.idea/

# goreleaser
dist/

# mdBook build output — generated by `make book` / `mdbook build book/`
# and deployed by .github/workflows/book.yml; never commit
book/book/

# Claude Code local state (worktrees, scheduled tasks, per-user settings)
.claude/

# Local secrets / per-run overrides for scripts/e2e-test-full.sh.
# Source with `set -a; . .env; set +a` before invoking the script.
# NEVER commit — contains IBMCLOUD_API_KEY plus optional SSH target
# names. Copy .env.example as a starting point if one ever lands.
.env
.env.local
.env.*.local

# Local terraform var-file used for live `--var-file=./terraform.tfvars`
# verification — contains ibmcloud_api_key / bigip_password. NEVER commit.
/terraform.tfvars

# terraform init cache (provider/module downloads) — e.g. left by a
# `terraform validate` during a sprint. Never source; never commit.
.terraform/
*.tfstate
*.tfstate.backup
